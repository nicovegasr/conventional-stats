#!/usr/bin/env zsh
set -euo pipefail

# ── audit subcommand ──────────────────────────────────────────────────────────
# Surfaces change-frequency hotspots: files with many big changes are likely
# code smells. Signal = commits touching the file × churn (lines added+deleted),
# so a file that changes often AND heavily floats to the top.

# Default ignores: high-churn-by-design files that are not code smells.
AUDIT_DEFAULT_IGNORE=(
  '*.lock'
  'package-lock.json'
  'pnpm-lock.yaml'
  'yarn.lock'
  'go.sum'
  'dist/'
  'build/'
  'node_modules/'
  'vendor/'
)

# is_audit_ignored PATH — true if PATH matches any pattern in AUDIT_IGNORE.
# Patterns: "dir/" → any path under that dir; "a/b" globs → matched against the
# full path (anchored or under any parent); bare globs → matched on the basename.
is_audit_ignored() {
  local file="$1" pat p base="${1:t}"
  for pat in "${AUDIT_IGNORE[@]}"; do
    if [[ "$pat" == */ ]]; then
      [[ "$file" == ${~pat}* || "$file" == *"/${pat}"* ]] && return 0
      continue
    fi
    p="${pat#/}"                       # tolerate leading slash (e.g. /build/*)
    if [[ "$p" == */* ]]; then
      [[ "$file" == ${~p} || "$file" == */${~p} ]] && return 0
    else
      [[ "$base" == ${~p} ]] && return 0
    fi
  done
  return 1
}

if [[ "${1:-}" == "audit" ]]; then
  shift

  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo "Uso: conventional-stats audit [opciones]"
    echo ""
    echo "  Lista archivos hotspot: muchos cambios y grandes (posibles code smells)."
    echo "  Barra = commits × líneas; color = ratio de fix/hotfix (inestabilidad)."
    echo "  Audita el repositorio actual salvo que pases --repo."
    echo ""
    echo "  --days N             Limitar a los últimos N días (default: todo)"
    echo "  --repo PATH          Auditar otro repositorio (default: directorio actual)"
    echo "  --json               JSON completo (a stdout si hay pipe; si no, a audit.json)"
    echo "  --ignore PATRÓN...   Excluir archivos (glob/dir). Ej: --ignore '*.gradle' '/build/*'"
    echo "  --set-ignore PATRÓN... Guardar patrones en .auditignore del repo y salir"
    echo "  --init-ignore        Crear un .auditignore de plantilla (con defaults comunes) y salir"
    echo ""
    echo "Ejemplos:"
    echo "  conventional-stats audit"
    echo "  conventional-stats audit --days 90"
    echo "  conventional-stats audit --ignore '*.gradle' '/build/*'"
    echo "  conventional-stats audit --repo ~/proyectos/mi-app --days 90"
    echo "  conventional-stats audit --set-ignore '*.gradle' '/build/*'"
    exit 0
  fi

  AUDIT_FORMAT="text"
  AUDIT_REPO="."
  AUDIT_DAYS=""
  AUDIT_INLINE_IGNORE=()
  AUDIT_SET_IGNORE=()
  AUDIT_INIT_IGNORE=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) AUDIT_FORMAT="json"; shift ;;
      --init-ignore) AUDIT_INIT_IGNORE=1; shift ;;
      --days)
        shift
        [[ $# -gt 0 && "$1" != --* ]] || { echo "Error: --days requiere un número." >&2; exit 1; }
        AUDIT_DAYS="$1"; shift
        ;;
      --repo)
        shift
        [[ $# -gt 0 && "$1" != --* ]] || { echo "Error: --repo requiere una ruta." >&2; exit 1; }
        AUDIT_REPO="$1"; shift
        ;;
      --ignore)
        shift
        while [[ $# -gt 0 && "$1" != --* ]]; do AUDIT_INLINE_IGNORE+=("$1"); shift; done
        ;;
      --set-ignore)
        shift
        while [[ $# -gt 0 && "$1" != --* ]]; do AUDIT_SET_IGNORE+=("$1"); shift; done
        ;;
      *) echo "Error: opción desconocida '$1'." >&2; exit 1 ;;
    esac
  done

  if [[ -n "$AUDIT_DAYS" && ! "$AUDIT_DAYS" == <-> ]]; then
    echo "Error: --days debe ser un número entero (recibido '$AUDIT_DAYS')." >&2
    exit 1
  fi

  if ! git -C "$AUDIT_REPO" rev-parse --git-dir &>/dev/null; then
    echo "Error: '$AUDIT_REPO' no es un repositorio git." >&2
    exit 1
  fi
  AUDIT_ROOT="$(git -C "$AUDIT_REPO" rev-parse --show-toplevel)"

  # --init-ignore: scaffold a generous, commented .auditignore (like a generated
  # .gitignore) for the user to prune. Never clobbers an existing one.
  if [[ "$AUDIT_INIT_IGNORE" == 1 ]]; then
    IGNORE_FILE="$AUDIT_ROOT/.auditignore"
    if [[ -f "$IGNORE_FILE" ]]; then
      echo "⚠ Ya existe $IGNORE_FILE — no se sobrescribe. Bórralo si quieres regenerarlo." >&2
      exit 1
    fi
    cat > "$IGNORE_FILE" <<'EOF'
# .auditignore — patrones excluidos de 'conventional-stats audit'.
# Archivos high-churn por diseño que NO son code smells. Esto es una plantilla:
# borra lo que no aplique a tu proyecto. Un patrón por línea (glob o dir/).

# ── Lockfiles ──
*.lock
package-lock.json
pnpm-lock.yaml
yarn.lock
bun.lockb
go.sum
Gemfile.lock
Cargo.lock
composer.lock
poetry.lock
Pipfile.lock

# ── Build / salida ──
dist/
build/
out/
target/
bin/
obj/
.next/
.nuxt/
.svelte-kit/
.output/
coverage/

# ── Dependencias ──
node_modules/
vendor/
.venv/
venv/

# ── Generados ──
*.min.js
*.min.css
*.map
*.generated.*
*.gen.go
*.pb.go
__snapshots__/
*.snap

# ── Manifiestos / changelogs (cambian en cada release) ──
CHANGELOG.md
package.json
.changeset/

# ── Docs / texto (descomenta si no quieres auditarlos) ──
# *.md
# docs/
EOF
    echo "✓ Creado $IGNORE_FILE — revísalo y borra lo que no aplique."
    exit 0
  fi

  # --set-ignore: persist patterns in <repo>/.auditignore, dedupe, then exit.
  if [[ ${#AUDIT_SET_IGNORE[@]} -gt 0 ]]; then
    IGNORE_FILE="$AUDIT_ROOT/.auditignore"
    if [[ ! -f "$IGNORE_FILE" ]]; then
      print -r -- "# Archivos excluidos de 'conventional-stats audit' — high-churn por diseño." > "$IGNORE_FILE"
      print -r -- "# Un patrón por línea (glob o dir/). Se suman a los defaults internos." >> "$IGNORE_FILE"
    fi
    added=0
    for pat in "${AUDIT_SET_IGNORE[@]}"; do
      if grep -qxF -- "$pat" "$IGNORE_FILE" 2>/dev/null; then continue; fi
      print -r -- "$pat" >> "$IGNORE_FILE"
      added=$((added + 1))
    done
    echo "✓ ${added} patrón(es) guardado(s) en $IGNORE_FILE"
    exit 0
  fi

  # Build active ignore set: defaults + .auditignore file + inline --ignore.
  AUDIT_IGNORE=("${AUDIT_DEFAULT_IGNORE[@]}")
  if [[ -f "$AUDIT_ROOT/.auditignore" ]]; then
    while IFS= read -r line; do
      line="${line## }"; line="${line%% }"
      [[ -z "$line" || "$line" == \#* ]] && continue
      AUDIT_IGNORE+=("$line")
    done < "$AUDIT_ROOT/.auditignore"
  fi
  AUDIT_IGNORE+=("${AUDIT_INLINE_IGNORE[@]}")

  AUDIT_SINCE=()
  AUDIT_PERIOD="todo el historial"
  if [[ -n "$AUDIT_DAYS" ]]; then
    AUDIT_SINCE=(--since="${AUDIT_DAYS} days ago")
    AUDIT_PERIOD="últimos ${AUDIT_DAYS} días"
  fi
  AUDIT_REPO_NAME="$(basename "$AUDIT_ROOT")"

  # Aggregate per file in a single awk pass — far faster than a zsh read-loop
  # on repos with thousands of commits. git emits, per commit: a subject line
  # (NF==1, from --pretty) followed by numstat lines (NF>=3: added, deleted,
  # path). --no-renames keeps paths clean ("a => b" / "{a => b}" are avoided).
  # awk output per file: commits<TAB>churn<TAB>fixes<TAB>type:n,...<TAB>path
  # core.quotePath=false keeps non-ASCII paths as raw UTF-8 (otherwise git wraps
  # them in quotes with octal escapes, which mangles both the render and JSON).
  audit_aggregate() {
    git -C "$AUDIT_ROOT" -c core.quotePath=false log "${AUDIT_SINCE[@]}" \
      --numstat --no-renames --pretty=format:'%s' 2>/dev/null |
    awk -F'\t' '
      NF < 3 {                                   # subject line of a commit
        if ($0 == "") next
        is_fix = ($0 ~ /^(fix|hotfix)(\(.*\))?!?:/)
        # Only treat a leading word as a type when it has the conventional
        # "type:" / "type(scope):" shape; anything else is "other".
        ctype = "other"
        if ($0 ~ /^[a-z]+(\([^)]*\))?!?:/) { match($0, /^[a-z]+/); ctype = substr($0, RSTART, RLENGTH) }
        next
      }
      {                                          # numstat line of that commit
        a = ($1 == "-") ? 0 : $1
        d = ($2 == "-") ? 0 : $2
        f = $3
        seen[f]    = 1
        commits[f] += 1
        churn[f]   += a + d
        if (is_fix) fixes[f] += 1
        key = f SUBSEP ctype
        if (!(key in tc)) tlist[f] = tlist[f] (tlist[f] == "" ? "" : " ") ctype
        tc[key] += 1
      }
      END {
        for (f in seen) {
          n = split(tlist[f], ts, " "); tb = ""
          for (i = 1; i <= n; i++)
            tb = tb (i > 1 ? "," : "") ts[i] ":" tc[f SUBSEP ts[i]]
          printf "%d\t%d\t%d\t%s\t%s\n", commits[f], churn[f], fixes[f] + 0, tb, f
        }
      }
    '
  }

  # Walking the whole history with --numstat is the slow step (seconds on big
  # repos), so show a spinner on stderr while it runs — only when stderr is a
  # terminal, so pipes/redirects/CI stay clean. A rough ETA (~1ms/commit) gives
  # the user a sense of the wait.
  _audit_spinner() {
    local msg="$1" frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏') i=0
    while :; do
      print -n "\r  ${frames[$((i % 10 + 1))]} ${msg}…" >&2
      sleep 0.1; (( i++ ))
    done
  }

  AUDIT_RAW=""
  if [[ -t 2 ]]; then
    n_commits=$(git -C "$AUDIT_ROOT" rev-list --count "${AUDIT_SINCE[@]}" HEAD 2>/dev/null || echo 0)
    spin_msg="auditando ${n_commits} commits"
    (( n_commits / 1000 >= 2 )) && spin_msg="${spin_msg} (~$(( n_commits / 1000 ))s)"
    _audit_spinner "$spin_msg" & spin_pid=$!
    AUDIT_RAW="$(audit_aggregate)"
    kill "$spin_pid" 2>/dev/null || true; wait "$spin_pid" 2>/dev/null || true
    print -n "\r\033[K" >&2          # erase the spinner line
  else
    AUDIT_RAW="$(audit_aggregate)"
  fi

  # Drop ignored files (cheap: one pass over ~hundreds of aggregated files, not
  # thousands of commits) and build sortable rows: score<TAB>commits<TAB>churn<TAB>fixes<TAB>types<TAB>path
  typeset -a audit_rows=()
  while IFS=$'\t' read -r c ch fx tb file; do
    [[ -z "$file" ]] && continue
    is_audit_ignored "$file" && continue
    score=$(( c * ch ))
    audit_rows+=("${score}	${c}	${ch}	${fx}	${tb}	${file}")
  done <<< "$AUDIT_RAW"

  # Rows start with the numeric score, so (On) = reverse numeric sort by score.
  typeset -a audit_sorted=()
  if [[ ${#audit_rows[@]} -gt 0 ]]; then
    audit_sorted=("${(@On)audit_rows}")
  fi

  AUDIT_LIMIT=20

  # ── JSON: complete, untruncated, with per-type breakdown ──────────────────
  # Built in a single awk pass over the sorted rows — a zsh loop here was the
  # slowest part of --json (seconds on big repos: thousands of iterations with
  # nested string ops). Rows are score<TAB>commits<TAB>churn<TAB>fixes<TAB>types<TAB>path.
  _audit_emit_json() {
    printf '%s\n' "${audit_sorted[@]}" |
    awk -F'\t' -v repo="$AUDIT_REPO_NAME" -v period="$AUDIT_PERIOD" '
      function esc(s) { gsub(/\\/, "\\\\", s); gsub(/"/, "\\\"", s); return s }
      BEGIN {
        printf "{\n  \"repo\": \"%s\",\n  \"period\": \"%s\",\n  \"hotspots\": [", esc(repo), esc(period)
        first = 1
      }
      NF >= 6 {
        tj = ""                                   # "feat:3,fix:2" → "feat": 3, "fix": 2
        if ($5 != "") {
          n = split($5, ps, ",")
          for (k = 1; k <= n; k++) { split(ps[k], kv, ":"); tj = tj (k > 1 ? ", " : "") "\"" kv[1] "\": " kv[2] }
        }
        printf "%s\n    { \"file\": \"%s\", \"commits\": %d, \"churn\": %d, \"fixes\": %d, \"score\": %d, \"types\": { %s } }", \
          (first ? "" : ","), esc($6), $2, $3, $4, $1, tj
        first = 0
      }
      END { printf "%s  ]\n}\n", (first ? "" : "\n") }
    '
  }

  if [[ "$AUDIT_FORMAT" == "json" ]]; then
    # Piped/redirected → stream to stdout (keeps `| jq` and `> file.json`).
    # Interactive terminal → write a file instead of flooding the screen.
    if [[ -t 1 ]]; then
      out="audit.json"
      _audit_emit_json > "$out"
      echo "✓ ${#audit_sorted[@]} hotspots → ${out}"
    else
      _audit_emit_json
    fi
    exit 0
  fi

  # ── Text: bar = magnitude (score), color = instability (fix ratio) ────────
  # Only the unstable files get colour (bold bright yellow/red); everything else
  # stays dim so the conflictive ones pop instead of a wall of muted green.
  C_RED="" C_YEL="" C_DIM="" C_BOLD="" C_RST=""
  if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
    C_RED=$'\033[1;91m'; C_YEL=$'\033[1;93m'
    C_DIM=$'\033[2m'; C_BOLD=$'\033[1m'; C_RST=$'\033[0m'
  fi

  echo ""
  echo "${C_BOLD}🔥 audit · ${AUDIT_REPO_NAME}${C_RST} ${C_DIM}— ${AUDIT_PERIOD}${C_RST}"
  echo ""
  if [[ ${#audit_sorted[@]} -eq 0 ]]; then
    echo "  ${C_DIM}Sin cambios en este rango.${C_RST}"
    echo ""
    exit 0
  fi

  # Top score (rows are sorted desc) sets the full-width bar reference.
  IFS=$'\t' read -r AUDIT_MAX _rest <<< "${audit_sorted[1]}"
  (( AUDIT_MAX < 1 )) && AUDIT_MAX=1

  # Name column = longest shown path, capped, so bars line up.
  BAR_W=22
  NAME_W=0
  i=1
  for row in "${audit_sorted[@]}"; do
    [[ $i -gt $AUDIT_LIMIT ]] && break
    IFS=$'\t' read -r _s _c _ch _fx _tb file <<< "$row"
    (( ${#file} > NAME_W )) && NAME_W=${#file}
    i=$((i + 1))
  done
  (( NAME_W > 36 )) && NAME_W=36

  i=1
  for row in "${audit_sorted[@]}"; do
    [[ $i -gt $AUDIT_LIMIT ]] && break
    IFS=$'\t' read -r score c ch fx tb file <<< "$row"

    disp="$file"
    (( ${#disp} > NAME_W )) && disp="…${disp[-$((NAME_W - 1)),-1]}"

    cols=$(( score * BAR_W / AUDIT_MAX ))
    (( cols < 1 && score > 0 )) && cols=1
    bar=""; (( cols > 0 )) && bar="$(printf '█%.0s' {1..$cols})"
    pad=$(( BAR_W - cols )); track=""; (( pad > 0 )) && track="$(printf '·%.0s' {1..$pad})"

    # Color = instability: fix ratio, but only flag when fixes >= 2 so a single
    # "1 commit = 1 fix" file stays neutral. Low ratio also stays dim so only the
    # genuinely conflictive files (high proportion of fixes) light up.
    col="$C_DIM"
    if (( fx >= 2 )); then
      pct=$(( fx * 100 / c ))
      if   (( pct >= 40 )); then col="$C_RED"
      elif (( pct >= 15 )); then col="$C_YEL"
      fi
    fi

    # Colour the whole row by risk so it reads as one band; keep the track dots
    # dim so the bar stays distinguishable from the empty remainder.
    printf "  ${col}%-*s  %s${C_RST}${C_DIM}%s${C_RST}  ${col}%d commits · %d líneas · %d fix${C_RST}\n" \
      "$NAME_W" "$disp" "$bar" "$track" "$c" "$ch" "$fx"
    i=$((i + 1))
  done

  shown=${#audit_sorted[@]}
  (( shown > AUDIT_LIMIT )) && shown=$AUDIT_LIMIT
  echo ""
  echo "  ${C_DIM}${#audit_sorted[@]} archivos · barra = commits × líneas · color = ratio de fix · top ${shown}${C_RST}"
  echo ""
  exit 0
fi

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  echo "Uso: conventional-stats [--json] [ruta-repo] [días]"
  echo "     conventional-stats audit [...]   (hotspots / code smells; ver --help)"
  echo ""
  echo "  --json      Salida en formato JSON"
  echo "  ruta-repo   Ruta al repositorio git (default: directorio actual)"
  echo "  días        Limitar al historial de los últimos N días (default: todo)"
  echo ""
  echo "Ejemplos:"
  echo "  conventional-stats"
  echo "  conventional-stats ~/proyectos/mi-app"
  echo "  conventional-stats ~/proyectos/mi-app 90"
  echo "  conventional-stats --json ~/proyectos/mi-app"
  echo "  conventional-stats --json ~/proyectos/mi-app 90"
  exit 0
fi

# Separate --json flag from positional args so it can appear anywhere
OUTPUT_FORMAT="text"
POSITIONAL_ARGS=()
for arg in "$@"; do
  if [[ "$arg" == "--json" ]]; then
    OUTPUT_FORMAT="json"
  else
    POSITIONAL_ARGS+=("$arg")
  fi
done

REPO_PATH="${POSITIONAL_ARGS[1]:-.}"
FILTER_DAYS="${POSITIONAL_ARGS[2]:-}"

if ! git -C "$REPO_PATH" rev-parse --git-dir &>/dev/null; then
  echo "Error: '$REPO_PATH' no es un repositorio git." >&2
  exit 1
fi

REPO_NAME=$(basename "$(git -C "$REPO_PATH" rev-parse --show-toplevel)")

# Array so "30 days ago" expands as one git argument, not three tokens
GIT_SINCE_FLAGS=()
PERIOD_LABEL="todo el historial"
if [[ -n "$FILTER_DAYS" ]]; then
  GIT_SINCE_FLAGS=(--since="${FILTER_DAYS} days ago")
  PERIOD_LABEL="últimos ${FILTER_DAYS} días"
fi

COMMIT_TYPES=(feat fix hotfix refactor red green docs style test chore perf ci build)

typeset -A type_counts
total_commits=0
max_type_count=0

while IFS= read -r commit_subject; do
  for commit_type in "${COMMIT_TYPES[@]}"; do
    if [[ "$commit_subject" =~ ^${commit_type}(\(.+\))?!?: ]]; then
      type_counts[$commit_type]=$(( ${type_counts[$commit_type]:-0} + 1 ))
      break
    fi
  done
done < <(git -C "$REPO_PATH" log --oneline "${GIT_SINCE_FLAGS[@]}" --format="%s" 2>/dev/null)

for commit_type in "${COMMIT_TYPES[@]}"; do
  count=${type_counts[$commit_type]:-0}
  type_counts[$commit_type]=$count
  total_commits=$((total_commits + count))
  [[ $count -gt $max_type_count ]] && max_type_count=$count
done

# ── JSON output ───────────────────────────────────────────────────────────────

if [[ "$OUTPUT_FORMAT" == "json" ]]; then
  typeset -a json_commit_entries=()
  for commit_type in "${COMMIT_TYPES[@]}"; do
    count=${type_counts[$commit_type]:-0}
    [[ $count -eq 0 ]] && continue
    json_commit_entries+=("    { \"type\": \"${commit_type}\", \"count\": ${count} }")
  done

  printf '{\n'
  printf '  "repo": "%s",\n' "$REPO_NAME"
  printf '  "period": "%s",\n' "$PERIOD_LABEL"
  printf '  "commits": [\n'
  local i=1
  for entry in "${json_commit_entries[@]}"; do
    if [[ $i -lt ${#json_commit_entries[@]} ]]; then
      printf '%s,\n' "$entry"
    else
      printf '%s\n' "$entry"
    fi
    i=$((i + 1))
  done
  printf '  ],\n'
  printf '  "total": %d\n' "$total_commits"
  printf '}\n'
  exit 0
fi

# ── Text output ───────────────────────────────────────────────────────────────

BAR_MAX_WIDTH=24

draw_bar() {
  local count=$1
  [[ $max_type_count -eq 0 ]] && return
  local bar_filled_cols=$(( count * BAR_MAX_WIDTH / max_type_count ))
  (( bar_filled_cols > 0 )) && repeat $bar_filled_cols { printf '█' }
}

echo ""
echo "📊 conventional-stats — ${REPO_NAME} (${PERIOD_LABEL})"
echo "──────────────────────────────────────────────────"

rows_printed=0
for commit_type in "${COMMIT_TYPES[@]}"; do
  count=${type_counts[$commit_type]:-0}
  [[ $count -eq 0 ]] && continue
  printf "  %-8s  %-${BAR_MAX_WIDTH}s  %s\n" "$commit_type" "$(draw_bar $count)" "$count"
  rows_printed=$((rows_printed + 1))
done

if [[ $rows_printed -eq 0 ]]; then
  echo "  Sin commits conventional en este rango."
fi

echo "──────────────────────────────────────────────────"
echo "  Total    ${total_commits} commits"
echo ""
