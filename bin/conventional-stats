#!/usr/bin/env zsh
set -euo pipefail

REPO="${1:-.}"
DAYS="${2:-}"

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  echo "Uso: conventional-stats [ruta-repo] [días]"
  echo ""
  echo "  ruta-repo   Ruta al repositorio git (default: directorio actual)"
  echo "  días        Limitar al historial de los últimos N días (default: todo)"
  echo ""
  echo "Ejemplos:"
  echo "  conventional-stats"
  echo "  conventional-stats ~/proyectos/mi-app"
  echo "  conventional-stats ~/proyectos/mi-app 90"
  exit 0
fi

if ! git -C "$REPO" rev-parse --git-dir &>/dev/null; then
  echo "Error: '$REPO' no es un repositorio git." >&2
  exit 1
fi

REPO_NAME=$(basename "$(git -C "$REPO" rev-parse --show-toplevel)")

SINCE=()
PERIOD="todo el historial"
if [[ -n "$DAYS" ]]; then
  SINCE=(--since="${DAYS} days ago")
  PERIOD="últimos ${DAYS} días"
fi

TYPES=(feat fix hotfix refactor red green docs style test chore perf ci build revert)
LABELS=(
  "feat    " "fix     " "hotfix  " "refactor"
  "red     " "green   " "docs    " "style   "
  "test    " "chore   " "perf    " "ci      "
  "build   " "revert  "
)

typeset -A counts
total=0
max=0

for type in "${TYPES[@]}"; do
  n=$(git -C "$REPO" log --oneline "${SINCE[@]}" --format="%s" 2>/dev/null \
    | grep -ciE "^${type}(\(.+\))?!?:" || true)
  counts[$type]=$n
  total=$((total + n))
  [[ $n -gt $max ]] && max=$n
done

BAR_WIDTH=24

bar() {
  local n=$1
  [[ $max -eq 0 ]] && return
  local filled=$(( n * BAR_WIDTH / max ))
  (( filled > 0 )) && repeat $filled { printf '█' }
}

echo ""
echo "📊 conventional-stats — ${REPO_NAME} (${PERIOD})"
echo "──────────────────────────────────────────────────"

printed=0
for i in {1..${#TYPES[@]}}; do
  type="${TYPES[$i]}"
  label="${LABELS[$i]}"
  n=${counts[$type]}
  [[ $n -eq 0 ]] && continue
  printf "  %s  %-${BAR_WIDTH}s  %s\n" "$label" "$(bar $n)" "$n"
  printed=$((printed + 1))
done

if [[ $printed -eq 0 ]]; then
  echo "  Sin commits conventional en este rango."
fi

echo "──────────────────────────────────────────────────"
echo "  Total    ${total} commits"
echo ""
